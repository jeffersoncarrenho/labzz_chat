{
    "info": {
        "name": "Labzz Chat API",
        "_postman_id": "labzz-chat-api",
        "description": "API collection for Labzz Chat System",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api/v1"
        },
        {
            "key": "token",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Auth - Login",
            "request": {
                "method": "POST",
                "header": [],
                "url": "{{base_url}}/auth/login",
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"user@email.com\",\n  \"password\": \"password\"\n}"
                }
            }
        },
        {
            "name": "Auth - Setup 2FA",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": "{{base_url}}/auth/2fa/setup"
            }
        },
        {
            "name": "Auth - Verify 2FA",
            "request": {
                "method": "POST",
                "header": [],
                "url": "{{base_url}}/auth/2fa/verify",
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"login_token\": \"TOKEN\",\n  \"code\": \"123456\"\n}"
                }
            }
        },
        {
            "name": "Users - List",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": "{{base_url}}/users"
            }
        },
        {
            "name": "Users - Create",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": "{{base_url}}/users",
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@email.com\",\n  \"password\": \"password\"\n}"
                }
            }
        },
        {
            "name": "Conversations - List",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": "{{base_url}}/conversations"
            }
        },
        {
            "name": "Conversations - Create",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": "{{base_url}}/conversations",
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"type\": \"private\",\n  \"participants\": [1,2]\n}"
                }
            }
        },
        {
            "name": "Messages - Send",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": "{{base_url}}/messages",
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"conversation_id\": 1,\n  \"content\": \"Hello world\"\n}"
                }
            }
        },
        {
            "name": "Messages - List",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": "{{base_url}}/conversations/1/messages"
            }
        }
    ]
}
